{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "Co-Authored-By: ruflo <ruv@ruv.net>",
    "pr": "Generated with [ruflo](https://github.com/ruvnet/ruflo)"
  },
  "permissions": {
    "allow": [
      "Bash(npx ruflo*)",
      "Bash(node /home/ummar/.claude/*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ],
    "defaultMode": "dontAsk"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/helpers/hook-handler.cjs pre-bash",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/helpers/hook-handler.cjs post-edit",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/helpers/quality-gate.cjs",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/hooks/iris-context-monitor.cjs",
            "timeout": 3000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/helpers/hook-handler.cjs route",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/helpers/hook-handler.cjs session-restore",
            "timeout": 15000
          },
          {
            "type": "command",
            "command": "node /home/ummar/.claude/helpers/auto-memory-hook.mjs import",
            "timeout": 8000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/helpers/auto-memory-hook.mjs sync",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/helpers/hook-handler.cjs compact-manual"
          }
        ]
      },
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/helpers/hook-handler.cjs compact-auto"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node /home/ummar/.claude/helpers/statusline.cjs"
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "superpowers@superpowers-dev": true,
    "document-skills@anthropic-agent-skills": true,
    "example-skills@anthropic-agent-skills": true,
    "obsidian@obsidian-skills": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "claude-api@anthropic-agent-skills": true
  },
  "extraKnownMarketplaces": {
    "thedotmack": {
      "source": {
        "source": "git",
        "url": "https://github.com/thedotmack/claude-mem.git"
      }
    },
    "superpowers-dev": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    },
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "github",
        "repo": "nextlevelbuilder/ui-ux-pro-max-skill"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true
}
