{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(node /home/ummar/.claude/*)",
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(npm install*)",
      "Bash(npx *)",
      "Bash(git *)",
      "Bash(python -m pytest*)",
      "Bash(python -m ruff*)",
      "Bash(python -m mypy*)",
      "Bash(cargo test*)",
      "Bash(cargo build*)",
      "Bash(cargo clippy*)",
      "Bash(bun run *)",
      "Bash(bun test*)",
      "Bash(pnpm run *)",
      "Bash(pnpm test*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(which *)",
      "Bash(gh *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/helpers/hook-handler.cjs pre-bash",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/hooks/auto-memory-recall.cjs",
            "timeout": 3000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/helpers/hook-handler.cjs post-edit",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/helpers/quality-gate.cjs",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/hooks/debt-scanner.cjs",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/hooks/progress-tracker.cjs --checkpoint",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/hooks/self-heal.cjs",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/hooks/context-monitor.cjs",
            "timeout": 3000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/helpers/hook-handler.cjs route",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "node /home/ummar/.claude/hooks/auto-memory-recall.cjs",
            "timeout": 3000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/helpers/hook-handler.cjs session-restore",
            "timeout": 15000
          },
          {
            "type": "command",
            "command": "node /home/ummar/.claude/helpers/auto-memory-hook.mjs import",
            "timeout": 8000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/helpers/auto-memory-hook.mjs sync",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "node /home/ummar/.claude/hooks/progress-tracker.cjs",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node /home/ummar/.claude/hooks/stop-telegram.cjs",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/helpers/hook-handler.cjs compact-manual"
          }
        ]
      },
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ummar/.claude/helpers/hook-handler.cjs compact-auto"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/ummar/.claude/scripts/session-summary.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node /home/ummar/.claude/helpers/statusline.cjs"
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": false,
    "superpowers@superpowers-dev": true,
    "document-skills@anthropic-agent-skills": true,
    "example-skills@anthropic-agent-skills": true,
    "obsidian@obsidian-skills": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "claude-api@anthropic-agent-skills": true,
    "clangd-lsp@claude-plugins-official": true,
    "comprehensive-review@claude-code-workflows": true,
    "debugging-toolkit@claude-code-workflows": true,
    "agent-orchestration@claude-code-workflows": true,
    "backend-development@claude-code-workflows": true,
    "telegram@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "thedotmack": {
      "source": {
        "source": "git",
        "url": "https://github.com/thedotmack/claude-mem.git"
      }
    },
    "superpowers-dev": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    },
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "github",
        "repo": "nextlevelbuilder/ui-ux-pro-max-skill"
      }
    },
    "claude-code-workflows": {
      "source": {
        "source": "github",
        "repo": "wshobson/agents"
      }
    }
  },
  "effortLevel": "xhigh",
  "showClearContextOnPlanAccept": true,
  "teammateMode": "tmux",
  "skipAutoPermissionPrompt": true
}
